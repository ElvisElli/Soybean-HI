arrange(desc(n))
print(focus_summary)
# Create the map plot
ggplot() +
# Plot world map
geom_polygon(data = world_map, aes(x = long, y = lat, group = group),
fill = "lightgray", color = "white", alpha = 0.8) +
# Plot research locations
geom_point(data = soybean.hi.data,
aes(x = Long, y = Lat, color = Country, size = Paper_Year),
alpha = 0.7) +
# Add labels for some key locations
geom_text_repel(data = soybean.hi.data %>%
group_by(Country) %>%
slice(1),
aes(x = Long, y = Lat, label = Country),
size = 3, box.padding = 0.5) +
# Styling
scale_size_continuous(name = "Publication Year",
range = c(2, 6),
breaks = seq(1980, 2025, by = 5)) +
scale_color_viridis_d(name = "Country") +
labs(title = "Global Distribution of Soybean Research Studies",
subtitle = "Research locations focusing on yield, harvest index, and related traits (1979-2025)",
x = "Longitude",
y = "Latitude",
caption = "Data from 43 scientific papers on soybean research") +
theme_minimal() +
theme(legend.position = "none",
plot.title = element_text(hjust = 0.5, face = "bold"),
plot.subtitle = element_text(hjust = 0.5))
